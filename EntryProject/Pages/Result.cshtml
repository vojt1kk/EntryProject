@page
@model ResultModel
@{
    ViewData["Title"] = "Výsledek triáže";
}

<div class="panel">
    <h1>Váš výsledek</h1>
    <p class="lead">Role: <strong>@Model.RoleName</strong></p>

    <div class="sp-score">
        <div class="number">@Model.Score.SpScore</div>
        <div>SP Score (0–100)</div>
        <div class="level-badge">@Model.LevelName</div>
    </div>
</div>

<div class="panel">
    <h2>Skóre podle návyků</h2>
    @foreach (var habit in HabitCatalog.All)
    {
        var s = Model.Score.HabitScores[habit];
        <div class="score-row">
            <div class="score-header">
                <span>@HabitCatalog.Name(habit)</span>
                <span class="value">@s / 100</span>
            </div>
            <div class="bar"><span style="width:@s%"></span></div>
        </div>
    }
</div>

<div class="panel">
    <h2>Doporučený studijní plán</h2>
    <ol class="steps">
        @foreach (var step in Model.Recommendation.Steps)
        {
            <li>@step</li>
        }
    </ol>

    @if (!string.IsNullOrEmpty(Model.Recommendation.RoleTip))
    {
        <p class="lead" style="margin-top:8px;"><strong>Tip pro vaši roli:</strong> @Model.Recommendation.RoleTip</p>
    }

    @if (Model.Recommendation.Masterclass)
    {
        <div class="masterclass">
            <strong>Navíc pro management:</strong> @Model.Recommendation.MasterclassText
        </div>
    }
</div>

<div class="panel">
    <h2>Dvě nejslabší oblasti</h2>
    @foreach (var area in Model.Recommendation.WeakestAreas)
    {
        <div class="weak-area">
            <strong>@HabitCatalog.Name(area.Habit) (@area.Score/100)</strong>
            <div>@area.Comment</div>
        </div>
    }
</div>

<div style="margin-top:8px;">
    <a class="btn" asp-page="/Index">Zpět na začátek</a>
    <a class="btn" asp-page="/Statistics" style="background:var(--color-accent);">Zobrazit statistiky</a>
</div>
